# --- Vector store -----------------------------------------------------------
QDRANT_COLLECTION=qabuddy_kb
QDRANT_PATH=./qdrant_data
# Server mode (droplet / docker-compose): uncomment and point at the container
# QDRANT_URL=http://localhost:6333

# --- Models (open source, run locally) --------------------------------------
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
BGE_USE_FP16=1

# --- LLM brain: Groq hosting the open-weight gpt-oss-120b -------------------
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-120b
GROQ_API_KEY=your_groq_key_here

# --- Server -----------------------------------------------------------------
PORT=5080

# --- JIRA (REST pull; MCP pulls also land in data/04_jira_tickets) ----------
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=
# JIRA_JQL=project = VWO ORDER BY updated DESC
